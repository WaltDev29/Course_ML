    "# 기대값"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "66a8c6e0",
   "metadata": {},
   "source": [
    "주사위를 굴려서 홀수면 -$0.5, 짝수면 + $1.0 달러일 때 => 기대값은 $0.25"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f7939ed6",
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "\n",
    "def is_even(n):\n",
    "    return n%2==0\n",
    "\n",
    "\n",
    "winnings = 0.0\n",
    "\n",
    "for i in range(10000):\n",
    "    die_toss = np.random.randint(1,7)\n",
    "    winnings += 1.0 if is_even(die_toss) else - 0.5\n",
    "\n",
    "print(winnings)"
   ]
  }
 ],
